    int sx = out_px.x & 1;
    int sy = out_px.y & 1;
    int idx = sy * 2 + sx;
    ivec2 src_px = out_px / 2;
    ivec2 base = src_px * ivec2(3, 1);
    vec4 t0 = texelFetch(conv2_raw, base + ivec2(0, 0), 0);
    vec4 t1 = texelFetch(conv2_raw, base + ivec2(1, 0), 0);
    vec4 t2 = texelFetch(conv2_raw, base + ivec2(2, 0), 0);
    int base_ch = idx * 3;
    int r_ch = base_ch + 0;
    int g_ch = base_ch + 1;
    int b_ch = base_ch + 2;
    int r_tile = r_ch / 4;
    int g_tile = g_ch / 4;
    int b_tile = b_ch / 4;
    int r_lane = r_ch % 4;
    int g_lane = g_ch % 4;
    int b_lane = b_ch % 4;
    vec4 rv = (r_tile == 0) ? t0 : ((r_tile == 1) ? t1 : t2);
    vec4 gv = (g_tile == 0) ? t0 : ((g_tile == 1) ? t1 : t2);
    vec4 bv = (b_tile == 0) ? t0 : ((b_tile == 1) ? t1 : t2);
    float r = rv[r_lane];
    float g = gv[g_lane];
    float b = bv[b_lane];
    result.rgb = vec3(r, g, b);
    imageStore(out_image, out_px, clamp(result, 0.0, 1.0));
}
