    int g_tile = g_ch / 4;
    int b_tile = b_ch / 4;
    int r_lane = r_ch % 4;
    int g_lane = g_ch % 4;
    int b_lane = b_ch % 4;
    vec4 rv = (r_tile == 0) ? t0 : ((r_tile == 1) ? t1 : t2);
