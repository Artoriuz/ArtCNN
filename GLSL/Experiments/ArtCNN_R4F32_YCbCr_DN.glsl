    int r_ch = base_ch + 0;
    int g_ch = base_ch + 1;
    int b_ch = base_ch + 2;
    int r_tile = r_ch / 4;
    int g_tile = g_ch / 4;
    int b_tile = b_ch / 4;
    int r_lane = r_ch % 4;
    int g_lane = g_ch % 4;
    int b_lane = b_ch % 4;
    vec4 rv = (r_tile == 0) ? t0 : ((r_tile == 1) ? t1 : t2);
    vec4 gv = (g_tile == 0) ? t0 : ((g_tile == 1) ? t1 : t2);
