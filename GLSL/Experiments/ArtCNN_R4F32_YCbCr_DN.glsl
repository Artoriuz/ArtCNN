    vec4 t0 = texelFetch(conv2_raw, base + ivec2(0, 0), 0);
    vec4 t1 = texelFetch(conv2_raw, base + ivec2(1, 0), 0);
    vec4 t2 = texelFetch(conv2_raw, base + ivec2(2, 0), 0);
