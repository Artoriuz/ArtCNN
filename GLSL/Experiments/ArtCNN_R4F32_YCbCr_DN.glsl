//!DESC ArtCNN_R4F32 YCbCr DN (Depth-To-Space)
//!COMPUTE 12 16 12 16
//!HOOK NATIVE
//!BIND conv2
//!WIDTH NATIVE.w 2.0 *
//!HEIGHT NATIVE.h 2.0 *
//!COMPONENTS 4

#extension GL_EXT_shader_explicit_arithmetic_types_float16 : enable
#ifdef GL_EXT_shader_explicit_arithmetic_types_float16
